# ═══════════════════════════════════════════════════════════════
# VENDURE BACKEND URL (required for POS GraphQL queries)
# ═══════════════════════════════════════════════════════════════
# Used by the BROWSER (POS UI) to talk to Vendure's /admin-api and /shop-api.
# Include http(s)://, no trailing slash, no path suffix.
#
# Local dev:                  http://127.0.0.1:3000
# Same LAN, different host:   http://192.168.1.10:3000
# Production (with proxy):    https://api.yourdomain.com
NEXT_PUBLIC_VENDURE_API_URL=http://127.0.0.1:3000

# Server-side fallback for /api routes (e.g., barcode scan endpoint).
VENDURE_SHOP_API_URL=http://127.0.0.1:3000/shop-api

# Vendure Channel Token (optional, defaults to __default_channel__)
VENDURE_CHANNEL_TOKEN=__default_channel__
# Or use public variant if needed client-side
# NEXT_PUBLIC_VENDURE_CHANNEL_TOKEN=__default_channel__

# Site URL for metadata/SEO (optional, defaults to https://example.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Cache Revalidation Secret (required for /api/revalidate endpoint)
# Generate a secure random string, e.g.: openssl rand -base64 32
REVALIDATION_SECRET=your-secure-random-string-here

# Site Name for metadata/SEO (optional, defaults to Vendure Store)
# NEXT_PUBLIC_SITE_NAME=Vendure Store

# Vendure Auth Token Cookie Name (optional, defaults to vendure-auth-token)
# VENDURE_AUTH_TOKEN_COOKIE=vendure-auth-token

# Vendure Auth Token Header Name (optional, defaults to vendure-auth-token)
# VENDURE_AUTH_TOKEN_HEADER=vendure-auth-token

# Vendure Channel Token Header Name (optional, defaults to vendure-token)
# VENDURE_CHANNEL_TOKEN_HEADER=vendure-token
